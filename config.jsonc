{
  "listen_addr": "[::]:4488",
  "multicore": true,
  "log_level": "info",
  "log_file": "",
  "routes": {
    "google.com, www.google.com": {
      "addr": "tcp://127.0.0.1:10001"
    },
    "microsoft.com, bing.com, azure.com": {
      "addr": "unix:///tmp/mihomo.sock"
    },
    "updates.cdn-apple.com": {
      "addr": "tcp://localhost:443"
    },
    "*": {
      "addr": "tcp://127.0.0.1:4488"
    }
  }
}