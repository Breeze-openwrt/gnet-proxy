{
  "listen_addr": "[::]:443",
  "multicore": true,
  "log": {
    "disabled": false,
    "level": "info",
    "output": "",
    "timestamp": true
  },
  "routes": {
    "updates.cdn-apple.com": {
      "addr": "tcp://127.0.0.1:10443",
      "jump_start": 4, // 🌡️ 保持 4 个空闲链接待命
      "idle_timeout": 300 // 🍂 5 分钟不使用则自动销毁释放
    }
  }
}